import math
from datetime import datetime, timedelta, timezone
from typing import Any, TypedDict

try:
    import pandas as pd
except ImportError:
    pd = None  # type: ignore[assignment]

from config import (
    buses_collection,
    eta_model,
    live_bus_states_collection,
)
from services.route_service import (
    BusStop,
    RouteDetails,
    RoutePoint,
    get_route_details,
)

try:
    from services.eta_storage_service import store_prediction
except Exception:
    store_prediction = None  # type: ignore[assignment]


FEATURE_ORDER = [
    "distance_km",
    "current_speed_kmh",
    "hour_of_day",
    "day_of_week",
    "is_weekend",
    "traffic_level",
]

MODEL_VERSION = "random-forest-regressor-v1"
MODEL_FEATURE_SCHEMA_VERSION = 1

SRI_LANKA_TIMEZONE = timezone(
    timedelta(hours=5, minutes=30),
)
MAX_LIVE_LOCATION_AGE_SECONDS = 120
MAX_LOCATION_FUTURE_SECONDS = 30


class EtaPredictionError(Exception):
    def __init__(
        self,
        message: str,
        status_code: int,
    ) -> None:
        super().__init__(message)
        self.message = message
        self.status_code = status_code


class EtaPredictionRequest(TypedDict):
    busId: str
    routeNumber: str
    destinationStopId: str


def _parse_float(
    value: Any,
    minimum: float,
    maximum: float,
) -> float | None:
    if isinstance(value, bool):
        return None

    try:
        parsed_value = float(value)
    except (TypeError, ValueError):
        return None

    if not math.isfinite(parsed_value):
        return None

    if minimum <= parsed_value <= maximum:
        return parsed_value

    return None


def _parse_datetime(
    value: Any,
) -> datetime | None:
    if isinstance(value, datetime):
        if value.tzinfo is None:
            return value.replace(
                tzinfo=timezone.utc,
            )

        return value.astimezone(
            timezone.utc,
        )

    if isinstance(value, str):
        normalized_value = (
            value.strip().replace(
                "Z",
                "+00:00",
            )
        )

        if not normalized_value:
            return None

        try:
            parsed_value = datetime.fromisoformat(
                normalized_value,
            )
        except ValueError:
            return None

        if parsed_value.tzinfo is None:
            return parsed_value.replace(
                tzinfo=timezone.utc,
            )

        return parsed_value.astimezone(
            timezone.utc,
        )

    return None


def _extract_coordinate(
    value: Any,
) -> tuple[float, float] | None:
    """
    Return a coordinate as (latitude, longitude).

    Supported formats:

    {
        "latitude": 6.9,
        "longitude": 79.8
    }

    {
        "lat": 6.9,
        "lng": 79.8
    }

    {
        "location": {
            "type": "Point",
            "coordinates": [79.8, 6.9]
        }
    }
    """
    if not isinstance(value, dict):
        return None

    latitude = _parse_float(
        value.get(
            "latitude",
            value.get("lat"),
        ),
        -90,
        90,
    )
    longitude = _parse_float(
        value.get(
            "longitude",
            value.get("lng"),
        ),
        -180,
        180,
    )

    if (
        latitude is not None
        and longitude is not None
    ):
        return latitude, longitude

    location = value.get("location")

    if not isinstance(location, dict):
        return None

    coordinates = location.get(
        "coordinates"
    )

    if (
        not isinstance(
            coordinates,
            (list, tuple),
        )
        or len(coordinates) < 2
    ):
        return None

    longitude = _parse_float(
        coordinates[0],
        -180,
        180,
    )
    latitude = _parse_float(
        coordinates[1],
        -90,
        90,
    )

    if (
        latitude is None
        or longitude is None
    ):
        return None

    return latitude, longitude


def _normalize_name(
    value: Any,
) -> str:
    return " ".join(
        str(value or "")
        .strip()
        .lower()
        .split()
    )


def _resolve_stop_coordinates(
    route: RouteDetails,
    stop: BusStop,
) -> tuple[float, float] | None:
    """
    Resolve coordinates for a route stop.

    Priority:
    1. Coordinates stored on the stop
    2. Matching route terminal by ID
    3. Matching route terminal by name
    4. First/last terminal fallback for first/last stop
    """
    direct_coordinate = _extract_coordinate(
        stop
    )

    if direct_coordinate is not None:
        return direct_coordinate

    terminals = route.get(
        "terminals"
    ) or []
    stops = route.get("stops") or []

    stop_id = str(
        stop.get("id") or ""
    ).strip()
    stop_name = _normalize_name(
        stop.get("name")
    )

    for terminal in terminals:
        terminal_id = str(
            terminal.get("id") or ""
        ).strip()
        terminal_name = _normalize_name(
            terminal.get("name")
        )

        ids_match = bool(
            stop_id
            and terminal_id
            and stop_id == terminal_id
        )
        names_match = bool(
            stop_name
            and terminal_name
            and stop_name == terminal_name
        )

        if ids_match or names_match:
            coordinate = _extract_coordinate(
                terminal
            )

            if coordinate is not None:
                return coordinate

    if not terminals or not stops:
        return None

    stop_index = next(
        (
            index
            for index, route_stop
            in enumerate(stops)
            if str(
                route_stop.get("id") or ""
            ).strip()
            == stop_id
        ),
        -1,
    )

    if stop_index == 0:
        return _extract_coordinate(
            terminals[0]
        )

    if stop_index == len(stops) - 1:
        return _extract_coordinate(
            terminals[-1]
        )

    return None


def _valid_route_polyline(
    route: RouteDetails,
) -> list[RoutePoint]:
    """
    Normalize route geometry to the RoutePoint format expected by ETA code.

    The service supports both the legacy `polyline` field and a GeoJSON
    LineString stored in `geometry`.
    """
    normalized_polyline: list[RoutePoint] = []

    for point in route.get("polyline") or []:
        coordinate = _extract_coordinate(
            point
        )

        if coordinate is None:
            continue

        latitude, longitude = coordinate

        normalized_polyline.append({
            "latitude": latitude,
            "longitude": longitude,
        })

    if len(normalized_polyline) >= 2:
        return normalized_polyline

    geometry = route.get("geometry")

    if not isinstance(geometry, dict):
        return normalized_polyline

    if str(
        geometry.get("type") or ""
    ).strip() != "LineString":
        return normalized_polyline

    coordinates = geometry.get(
        "coordinates"
    )

    if not isinstance(
        coordinates,
        list,
    ):
        return normalized_polyline

    geojson_polyline: list[RoutePoint] = []

    for coordinate in coordinates:
        if (
            not isinstance(
                coordinate,
                (list, tuple),
            )
            or len(coordinate) < 2
        ):
            continue

        longitude = _parse_float(
            coordinate[0],
            -180,
            180,
        )
        latitude = _parse_float(
            coordinate[1],
            -90,
            90,
        )

        if (
            latitude is None
            or longitude is None
        ):
            continue

        geojson_polyline.append({
            "latitude": latitude,
            "longitude": longitude,
        })

    return geojson_polyline


def _get_bus_tracking_state(
    bus_id: str,
) -> dict[str, Any] | None:
    """
    Merge bus master data with the latest live GPS state.

    `live_bus_states` is authoritative for current location, timestamp,
    route, trip, speed, heading and operational status.
    """
    master_bus = buses_collection.find_one(
        {
            "$or": [
                {"bus_id": bus_id},
                {
                    "vehicleRegistrationNumber":
                        bus_id,
                },
            ],
        },
        {
            "_id": 0,
            "bus_id": 1,
            "vehicleRegistrationNumber": 1,
            "routeNumber": 1,
            "lat": 1,
            "lng": 1,
            "speed": 1,
            "heading": 1,
            "updatedAt": 1,
            "operationalStatus": 1,
            "isActive": 1,
            "tripId": 1,
            "activeTripId": 1,
        },
    )

    live_state = (
        live_bus_states_collection.find_one(
            {
                "busId": bus_id,
            },
            {
                "_id": 0,
                "busId": 1,
                "routeNumber": 1,
                "tripId": 1,
                "location": 1,
                "speed": 1,
                "heading": 1,
                "updatedAt": 1,
                "recordedAt": 1,
                "operationalStatus": 1,
            },
        )
    )

    if not live_state:
        return master_bus

    coordinate = _extract_coordinate({
        "location": live_state.get(
            "location"
        ),
    })

    if coordinate is None:
        return master_bus

    latitude, longitude = coordinate

    operational_status = str(
        live_state.get(
            "operationalStatus"
        )
        or "active"
    ).strip().lower()

    if operational_status not in {
        "active",
        "paused",
        "offline",
    }:
        operational_status = "active"

    merged_bus = dict(
        master_bus or {}
    )

    live_trip_id = str(
        live_state.get("tripId") or ""
    ).strip()

    merged_bus.update({
        "bus_id": bus_id,
        "vehicleRegistrationNumber": (
            merged_bus.get(
                "vehicleRegistrationNumber"
            )
            or bus_id
        ),
        "routeNumber": (
            live_state.get("routeNumber")
            or merged_bus.get(
                "routeNumber"
            )
        ),
        "lat": latitude,
        "lng": longitude,
        "speed": live_state.get(
            "speed",
            merged_bus.get("speed", 0),
        ),
        "heading": live_state.get(
            "heading",
            merged_bus.get("heading", 0),
        ),
        "updatedAt": (
            live_state.get("updatedAt")
            or live_state.get(
                "recordedAt"
            )
        ),
        "operationalStatus":
            operational_status,
        "isActive":
            operational_status == "active",
        "tripId": (
            live_trip_id
            or merged_bus.get("tripId")
        ),
        "activeTripId": (
            live_trip_id
            or merged_bus.get(
                "activeTripId"
            )
        ),
    })

    return merged_bus


def haversine_km(
    latitude_a: float,
    longitude_a: float,
    latitude_b: float,
    longitude_b: float,
) -> float:
    earth_radius_km = 6371.0

    delta_latitude = math.radians(
        latitude_b - latitude_a
    )
    delta_longitude = math.radians(
        longitude_b - longitude_a
    )

    start_latitude = math.radians(
        latitude_a
    )
    end_latitude = math.radians(
        latitude_b
    )

    haversine_value = (
        math.sin(
            delta_latitude / 2
        ) ** 2
        + math.cos(start_latitude)
        * math.cos(end_latitude)
        * math.sin(
            delta_longitude / 2
        ) ** 2
    )

    haversine_value = min(
        max(haversine_value, 0.0),
        1.0,
    )

    central_angle = 2 * math.atan2(
        math.sqrt(haversine_value),
        math.sqrt(
            1 - haversine_value
        ),
    )

    return earth_radius_km * central_angle


def _closest_polyline_index(
    latitude: float,
    longitude: float,
    polyline: list[RoutePoint],
) -> int:
    if not polyline:
        raise ValueError(
            "A non-empty route polyline is required."
        )

    closest_index = 0
    closest_distance = float("inf")

    for index, point in enumerate(
        polyline
    ):
        distance = haversine_km(
            latitude,
            longitude,
            point["latitude"],
            point["longitude"],
        )

        if distance < closest_distance:
            closest_distance = distance
            closest_index = index

    return closest_index


def _distance_along_polyline(
    polyline: list[RoutePoint],
    start_index: int,
    end_index: int,
) -> float:
    if end_index <= start_index:
        return 0.0

    distance = 0.0

    for index in range(
        start_index,
        end_index,
    ):
        start = polyline[index]
        end = polyline[index + 1]

        distance += haversine_km(
            start["latitude"],
            start["longitude"],
            end["latitude"],
            end["longitude"],
        )

    return distance


def calculate_remaining_distance_km(
    bus_latitude: float,
    bus_longitude: float,
    destination_stop: BusStop,
    route: RouteDetails,
) -> float:
    destination_coordinate = (
        _resolve_stop_coordinates(
            route,
            destination_stop,
        )
    )

    if destination_coordinate is None:
        raise EtaPredictionError(
            (
                "The selected destination does not "
                "have configured map coordinates."
            ),
            409,
        )

    (
        destination_latitude,
        destination_longitude,
    ) = destination_coordinate

    polyline = _valid_route_polyline(
        route
    )

    if len(polyline) < 2:
        return haversine_km(
            bus_latitude,
            bus_longitude,
            destination_latitude,
            destination_longitude,
        )

    bus_index = _closest_polyline_index(
        bus_latitude,
        bus_longitude,
        polyline,
    )

    destination_index = (
        _closest_polyline_index(
            destination_latitude,
            destination_longitude,
            polyline,
        )
    )

    if destination_index < bus_index:
        return haversine_km(
            bus_latitude,
            bus_longitude,
            destination_latitude,
            destination_longitude,
        )

    bus_snap_point = polyline[
        bus_index
    ]
    destination_snap_point = polyline[
        destination_index
    ]

    return (
        haversine_km(
            bus_latitude,
            bus_longitude,
            bus_snap_point["latitude"],
            bus_snap_point["longitude"],
        )
        + _distance_along_polyline(
            polyline,
            bus_index,
            destination_index,
        )
        + haversine_km(
            destination_snap_point[
                "latitude"
            ],
            destination_snap_point[
                "longitude"
            ],
            destination_latitude,
            destination_longitude,
        )
    )


def find_next_stop(
    bus_latitude: float,
    bus_longitude: float,
    route: RouteDetails,
) -> BusStop | None:
    stops = route.get("stops") or []

    if not stops:
        return None

    polyline = _valid_route_polyline(
        route
    )

    if len(polyline) < 2:
        return stops[-1]

    bus_index = _closest_polyline_index(
        bus_latitude,
        bus_longitude,
        polyline,
    )

    for stop in stops:
        stop_coordinate = (
            _resolve_stop_coordinates(
                route,
                stop,
            )
        )

        if stop_coordinate is None:
            continue

        (
            stop_latitude,
            stop_longitude,
        ) = stop_coordinate

        stop_index = _closest_polyline_index(
            stop_latitude,
            stop_longitude,
            polyline,
        )

        if stop_index >= bus_index:
            return stop

    return stops[-1]


def estimate_traffic_level(
    now: datetime,
) -> float:
    local_time = now.astimezone(
        SRI_LANKA_TIMEZONE
    )
    hour = local_time.hour
    weekday = local_time.weekday()
    is_weekend = weekday >= 5

    if (
        not is_weekend
        and (
            7 <= hour <= 9
            or 16 <= hour <= 19
        )
    ):
        return 0.8

    if (
        not is_weekend
        and 10 <= hour <= 15
    ):
        return 0.45

    return 0.15


def _get_destination_stop(
    route: RouteDetails,
    destination_stop_id: str,
) -> BusStop | None:
    for stop in route.get("stops") or []:
        if (
            str(stop.get("id") or "")
            == destination_stop_id
        ):
            return stop

    return None


def _validate_model() -> None:
    if eta_model is None:
        raise RuntimeError(
            "ETA model is not available."
        )

    if pd is None:
        raise RuntimeError(
            "pandas is unavailable."
        )

    feature_names = list(
        getattr(
            eta_model,
            "feature_names_in_",
            [],
        )
    )

    if (
        feature_names
        and feature_names != FEATURE_ORDER
    ):
        raise RuntimeError(
            (
                "ETA model feature schema mismatch. "
                f"Expected {FEATURE_ORDER}, "
                f"got {feature_names}. "
                "Retrain the model or roll back "
                "to feature schema "
                f"v{MODEL_FEATURE_SCHEMA_VERSION}."
            )
        )


def _deterministic_eta_minutes(
    remaining_distance_km: float,
    current_speed_kmh: float,
    now: datetime,
) -> float:
    """
    Deterministic fallback:

    ETA = distance / traffic-adjusted speed
    """
    traffic = estimate_traffic_level(
        now
    )

    speed_factor = (
        1.0 - traffic * 0.35
    )

    effective_speed = max(
        current_speed_kmh * speed_factor,
        5.0,
    )

    hours = (
        remaining_distance_km
        / effective_speed
    )

    return max(
        round(hours * 60, 2),
        0.5,
    )


def _build_model_features(
    remaining_distance_km: float,
    current_speed_kmh: float,
    now: datetime,
) -> dict[str, float | int]:
    local_time = now.astimezone(
        SRI_LANKA_TIMEZONE
    )
    weekday = local_time.weekday()

    return {
        "distance_km": round(
            min(
                max(
                    remaining_distance_km,
                    0.5,
                ),
                15.0,
            ),
            3,
        ),
        "current_speed_kmh": round(
            min(
                max(
                    current_speed_kmh,
                    3.0,
                ),
                80.0,
            ),
            2,
        ),
        "hour_of_day":
            local_time.hour,
        "day_of_week":
            weekday,
        "is_weekend":
            1 if weekday >= 5 else 0,
        "traffic_level":
            estimate_traffic_level(now),
    }


def _predict_eta_minutes(
    remaining_distance_km: float,
    current_speed_kmh: float,
    now: datetime,
) -> tuple[
    float,
    str,
    dict[str, Any],
]:
    """
    Use the ML model when possible and automatically fall back to the
    deterministic calculation when the model or its dependencies fail.
    """
    if eta_model is not None:
        try:
            _validate_model()

            features = _build_model_features(
                remaining_distance_km,
                current_speed_kmh,
                now,
            )

            feature_frame = pd.DataFrame(
                [
                    {
                        feature: features[
                            feature
                        ]
                        for feature
                        in FEATURE_ORDER
                    }
                ],
            )

            prediction_raw = float(
                eta_model.predict(
                    feature_frame
                )[0]
            )

            if (
                not math.isfinite(
                    prediction_raw
                )
                or prediction_raw < 0
            ):
                raise ValueError(
                    (
                        "ETA model returned an "
                        "invalid prediction."
                    )
                )

            return (
                round(
                    prediction_raw,
                    2,
                ),
                MODEL_VERSION,
                dict(features),
            )
        except Exception:
            pass

    deterministic_eta = (
        _deterministic_eta_minutes(
            remaining_distance_km,
            current_speed_kmh,
            now,
        )
    )

    return (
        deterministic_eta,
        "deterministic-v1",
        {
            "remaining_distance_km":
                remaining_distance_km,
            "current_speed_kmh":
                current_speed_kmh,
            "traffic_level":
                estimate_traffic_level(now),
        },
    )


def _store_prediction_safely(
    *,
    bus_id: str,
    route_id: str,
    route_number: str,
    trip_id: str | None,
    destination_stop_id: str,
    destination_stop_name: str,
    remaining_distance_km: float,
    eta_minutes: float,
    estimated_arrival_at: str,
    model_version: str,
    feature_snapshot: dict[str, Any],
) -> None:
    if not callable(
        store_prediction
    ):
        return

    try:
        store_prediction(
            bus_id=bus_id,
            route_id=route_id,
            route_number=route_number,
            trip_id=trip_id,
            destination_stop_id=(
                destination_stop_id
            ),
            destination_stop_name=(
                destination_stop_name
            ),
            remaining_distance_km=(
                remaining_distance_km
            ),
            eta_minutes=eta_minutes,
            estimated_arrival_at=(
                estimated_arrival_at
            ),
            model_version=model_version,
            feature_snapshot=(
                feature_snapshot
            ),
        )
    except Exception:
        # ETA delivery must not fail because analytics persistence failed.
        return


def build_eta_prediction(
    request_data: dict[str, Any],
) -> dict[str, Any]:
    if not isinstance(
        request_data,
        dict,
    ):
        raise EtaPredictionError(
            "A JSON request object is required.",
            400,
        )

    bus_id = str(
        request_data.get("busId") or ""
    ).strip()

    requested_route_number = str(
        request_data.get(
            "routeNumber"
        )
        or ""
    ).strip()

    destination_stop_id = str(
        request_data.get(
            "destinationStopId"
        )
        or ""
    ).strip()

    if (
        not bus_id
        or not destination_stop_id
    ):
        raise EtaPredictionError(
            (
                "busId and destinationStopId "
                "are required."
            ),
            400,
        )

    bus = _get_bus_tracking_state(
        bus_id
    )

    if not bus:
        raise EtaPredictionError(
            "Bus was not found.",
            404,
        )

    operational_status = str(
        bus.get(
            "operationalStatus"
        )
        or ""
    ).strip().lower()

    if (
        (
            operational_status
            and operational_status
            != "active"
        )
        or bus.get("isActive") is False
    ):
        raise EtaPredictionError(
            (
                "The selected bus is not "
                "running an active trip."
            ),
            409,
        )

    bus_route_number = str(
        bus.get("routeNumber") or ""
    ).strip()

    if (
        requested_route_number
        and bus_route_number
        and requested_route_number
        != bus_route_number
    ):
        raise EtaPredictionError(
            (
                "The selected bus does not "
                "belong to the requested route."
            ),
            409,
        )

    effective_route_number = (
        bus_route_number
        or requested_route_number
    )

    if not effective_route_number:
        raise EtaPredictionError(
            (
                "The selected bus does not "
                "have an assigned route."
            ),
            409,
        )

    route = get_route_details(
        effective_route_number
    )

    if route is None:
        raise EtaPredictionError(
            "Route was not found.",
            404,
        )

    destination_stop = (
        _get_destination_stop(
            route,
            destination_stop_id,
        )
    )

    if destination_stop is None:
        raise EtaPredictionError(
            (
                "Destination stop was not found "
                "on the selected route."
            ),
            404,
        )

    latitude = _parse_float(
        bus.get("lat"),
        -90,
        90,
    )
    longitude = _parse_float(
        bus.get("lng"),
        -180,
        180,
    )

    if (
        latitude is None
        or longitude is None
    ):
        raise EtaPredictionError(
            (
                "The selected bus does not "
                "have a valid current location."
            ),
            409,
        )

    updated_at = _parse_datetime(
        bus.get("updatedAt")
    )

    if updated_at is None:
        raise EtaPredictionError(
            (
                "The selected bus location does "
                "not have a valid timestamp."
            ),
            409,
        )

    now = datetime.now(
        timezone.utc
    )

    age_seconds = (
        now - updated_at
    ).total_seconds()

    if (
        age_seconds
        > MAX_LIVE_LOCATION_AGE_SECONDS
    ):
        raise EtaPredictionError(
            (
                "The selected bus is offline. "
                "Wait for a fresh GPS update."
            ),
            409,
        )

    if (
        age_seconds
        < -MAX_LOCATION_FUTURE_SECONDS
    ):
        raise EtaPredictionError(
            (
                "The selected bus location "
                "timestamp is in the future."
            ),
            409,
        )

    speed = _parse_float(
        bus.get("speed"),
        0,
        200,
    )

    current_speed_kmh = (
        speed
        if speed is not None
        and speed > 0
        else 25.0
    )

    remaining_distance_km = (
        calculate_remaining_distance_km(
            latitude,
            longitude,
            destination_stop,
            route,
        )
    )

    (
        eta_minutes,
        used_model_version,
        feature_snapshot,
    ) = _predict_eta_minutes(
        remaining_distance_km,
        current_speed_kmh,
        now,
    )

    arrival_time = (
        now.astimezone(
            SRI_LANKA_TIMEZONE
        )
        + timedelta(
            minutes=eta_minutes
        )
    )

    next_stop = find_next_stop(
        latitude,
        longitude,
        route,
    )

    estimated_arrival_iso = (
        arrival_time.isoformat()
    )

    route_id = str(
        route.get("id") or ""
    )

    trip_id_value = str(
        bus.get("tripId")
        or bus.get("activeTripId")
        or ""
    ).strip()

    destination_id = str(
        destination_stop.get("id")
        or destination_stop_id
    )

    destination_name = str(
        destination_stop.get("name")
        or "Destination"
    )

    _store_prediction_safely(
        bus_id=bus_id,
        route_id=route_id,
        route_number=(
            effective_route_number
        ),
        trip_id=(
            trip_id_value or None
        ),
        destination_stop_id=(
            destination_id
        ),
        destination_stop_name=(
            destination_name
        ),
        remaining_distance_km=(
            remaining_distance_km
        ),
        eta_minutes=eta_minutes,
        estimated_arrival_at=(
            estimated_arrival_iso
        ),
        model_version=(
            used_model_version
        ),
        feature_snapshot=(
            feature_snapshot
        ),
    )

    return {
        "status": "success",
        "busId": bus_id,
        "routeNumber":
            effective_route_number,
        "destinationStop": {
            "id": destination_id,
            "name": destination_name,
        },
        "nextStop": (
            {
                "id": str(
                    next_stop.get("id")
                    or ""
                ),
                "name": str(
                    next_stop.get("name")
                    or "Next stop"
                ),
            }
            if next_stop
            else None
        ),
        "etaMinutes":
            eta_minutes,
        "estimatedArrivalAt":
            estimated_arrival_iso,
        "remainingDistanceKm": round(
            remaining_distance_km,
            2,
        ),
        "modelVersion":
            used_model_version,
    }