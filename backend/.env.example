MONGO_URI=mongodb://localhost:27017
TEXTLK_API_TOKEN=your_textlk_api_token
TEXTLK_SENDER_ID=TextLKDemo

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_BUCKET=driver-documents

JWT_SECRET=replace_this_with_a_long_random_secret
ADMIN_EMAIL=admin@gamana.lk
ADMIN_PASSWORD_HASH=$2b$12$replace_this_with_a_valid_bcrypt_hash
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://localhost:8082
ENABLE_DEVELOPMENT_ROUTE_FALLBACK=true
FLASK_DEBUG=true

# Map and routing configuration
MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_ATTRIBUTION_TEXT="© OpenStreetMap contributors"
MAP_MIN_ZOOM=5
MAP_MAX_ZOOM=18
OSRM_BASE_URL=http://router.project-osrm.org
LOCATION_HISTORY_TTL_DAYS=90
ETA_MODEL_PATH=eta_model.pkl
