# Flask runtime
FLASK_DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# MongoDB
MONGO_URI=mongodb://localhost:27017

# Authentication (use at least 32 random bytes for JWT_SECRET)
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# TextLK OTP delivery
TEXTLK_API_TOKEN=
TEXTLK_SENDER_ID=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=driver-documents
