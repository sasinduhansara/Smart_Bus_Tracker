# In local Vite development, /api is proxied to Flask (no browser CORS needed).
VITE_API_URL=/api
# For production, replace the value above with the deployed Flask /api origin.
# Map configuration
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
VITE_MAP_ATTRIBUTION_TEXT="© OpenStreetMap contributors"
VITE_MAP_MIN_ZOOM=5
VITE_MAP_MAX_ZOOM=18
